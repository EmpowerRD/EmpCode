# Copy this file to `.env` and fill in any values you need.

# Optional. Subdomain only — e.g. "google" for google.atlassian.net.
# When set, shows an "Open Ticket" / "Create Ticket" button in the chat header
# that links to your Atlassian instance.
JIRA_DOMAIN=

# Optional. Restricts the Jira key input on threads to this project prefix.
# For example, JIRA_PROJECT_KEY=GOOG requires keys like GOOG-123.
# When unset, any uppercase prefix (ABC-123, FOO-7) is accepted.
JIRA_PROJECT_KEY=
